# =============================================
# 课堂派 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值
#   cp .env.example .env
# =============================================

# ---- 数据库 ----
DB_HOST=localhost
DB_PORT=3307
DB_NAME=ketangpai
DB_USERNAME=root
DB_PASSWORD=your-database-password

# ---- JWT ----
JWT_SECRET=your-jwt-secret-at-least-256-bits-long
JWT_EXPIRATION=86400000

# ---- MinIO 对象存储 ----
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=ketangpai

# ---- AI Chat（DeepSeek 等 OpenAI 兼容 API） ----
OPENAI_CHAT_API_KEY=sk-your-chat-api-key
OPENAI_CHAT_BASE_URL=https://api.deepseek.com
OPENAI_CHAT_MODEL=deepseek-v4-flash

# ---- AI Embedding（独立的 Embedding 服务） ----
OPENAI_EMBEDDING_API_KEY=sk-your-embedding-api-key
OPENAI_EMBEDDING_BASE_URL=https://your-embedding-api.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-v4

# ---- Qdrant 向量存储 (Docker) ----
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_COLLECTION=ketangpai-kb

# ---- 服务器 ----
SERVER_PORT=8080
